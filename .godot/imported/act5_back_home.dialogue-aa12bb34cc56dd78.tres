&"id": "1",
&"next_id": "2",
&"static_id": "",
&"text": "这窗花……真像你奶奶的手艺。",
&"type": "dialogue"
},
"2": {
&"character": "林师傅",
&"id": "2",
&"next_id": "3",
&"static_id": "",
&"text": "老宅子有了窗花，才算真正活过来了。",
&"type": "dialogue"
},
"3": {
&"character": "林师傅",
&"id": "3",
&"next_id": "4",
&"static_id": "",
&"text": "你看那光，透过窗花照进来，满屋子的影子都是花。",
&"type": "dialogue"
},
"4": {
&"character": "陈远",
&"id": "4",
&"next_id": "5",
&"static_id": "",
&"text": "爷爷，奶奶，老宅子……我帮你们守住了。",
&"type": "dialogue"
},
