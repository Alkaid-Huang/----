character_names = PackedStringArray("陈伯", "林师傅")
first_cue = "0"
lines = {
"0": {
&"id": "0",
&"next_id": "1",
&"type": "cue"
},
"1": {
&"character": "陈伯",
&"id": "1",
&"next_id": "2",
&"static_id": "",
&"text": "少了窗户。房子没有窗户，就跟人没有眼睛一样。",
&"type": "dialogue"
},
"2": {
&"character": "陈伯",
&"id": "2",
&"next_id": "3",
&"static_id": "",
&"text": "你爷爷以前说过——窗户是房子的眼睛，窗花是房子的魂。",
&"type": "dialogue"
},
"3": {
&"character": "陈伯",
&"id": "3",
&"next_id": "4",
&"static_id": "",
&"text": "咱们北方老宅子的窗棂有讲究——\"步步锦\"、\"龟背纹\"、\"冰裂纹\"，每种纹样都有寓意。步步锦是步步高升，龟背纹是长命百岁，冰裂纹是苦尽甘来。",
&"type": "dialogue"
},
"4": {
&"character": "林师傅",
&"id": "4",
&"next_id": "5",
&"static_id": "",
&"text": "窗棂的料我给你备好了。窗花嘛……你自己想办法。",
&"type": "dialogue"
},
"5": {
&"character": "林师傅",
&"id": "5",
&"next_id": "6",
&"static_id": "",
&"text": "你奶奶当年可是镇上剪窗花的一把好手。",
&"type": "dialogue"
},
"6": {
&"character": "林师傅",
&"id": "6",
&"next_id": "7",
&"static_id": "",
&"text": "剪纸这门手艺，在咱们中国已经一千多年了。最早是唐代，妇女用金箔银箔剪成花鸟贴在鬓角上，叫\"胜\"。后来慢慢变成贴在窗户上，图个喜庆。你奶奶的牡丹花样子，镇上没人能比。",
&"type": "dialogue"
},
"7": {
&"id": "7",
&"is_snippet": false,
&"next_id": "end",
&"next_id_after": "",
&"type": "goto"
},
"8": {
&"id": "8",
&"next_id": "9",
&"type": ""
},
"9": {
&"id": "9",
&"is_snippet": false,
&"next_id": "end",
&"next_id_after": "",
&"type": "goto"
}
}
metadata/dialogue_manager_version = "3.10.1"
