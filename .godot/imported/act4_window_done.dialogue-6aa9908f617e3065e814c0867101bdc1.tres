"1": {
&"character": "陈伯",
&"id": "1",
&"next_id": "2",
&"static_id": "",
&"text": "少了窗户。房子没有窗户，就跟人没有眼睛一样。",
&"type": "dialogue"
},
"2": {
&"character": "陈伯",
&"id": "2",
&"next_id": "3",
&"static_id": "",
&"text": "你爷爷以前说过——窗户是房子的眼睛，窗花是房子的魂。",
&"type": "dialogue"
},
"3": {
&"character": "林师傅",
&"id": "3",
&"next_id": "4",
&"static_id": "",
&"text": "窗棂的料我给你备好了。窗花嘛……你自己想办法。",
&"type": "dialogue"
},
"4": {
&"character": "林师傅",
&"id": "4",
&"next_id": "5",
&"static_id": "",
&"text": "你奶奶当年可是镇上剪窗花的一把好手。",
&"type": "dialogue"
},
"5": {
&"id": "5",
&"is_snippet": false,
&"next_id": "end",
&"next_id_after": "",
&"type": "goto"
},
