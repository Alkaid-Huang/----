"1": {
&"character": "陈远",
&"id": "1",
&"next_id": "2",
&"static_id": "",
&"text": "七年了……终于又回到青石镇了。",
&"type": "dialogue"
},
"2": {
&"character": "陈远",
&"id": "2",
&"next_id": "3",
&"static_id": "",
&"text": "父亲在电话里说，老宅快塌了，让我回来看看。",
&"type": "dialogue"
},
"3": {
&"character": "陈远",
&"id": "3",
&"next_id": "4",
&"static_id": "",
&"text": "我本来不想来。但昨晚梦见了祖父。",
&"type": "dialogue"
},
"4": {
&"character": "陈远",
&"id": "4",
&"next_id": "5",
&"static_id": "",
&"text": "梦里他坐在院子里，手里拿着一块刨光的木头，抬头对我笑了笑。",
&"type": "dialogue"
},
"5": {
&"character": "陈远",
&"id": "5",
&"next_id": "6",
&"static_id": "",
&"text": "醒了之后，我订了最早的车票。",
&"type": "dialogue"
},
"6": {
&"id": "6",
&"is_snippet": false,
&"next_id": "end",
&"next_id_after": "",
&"type": "goto"
},
"7": {
