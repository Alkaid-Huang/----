},
"1": {
&"character": "陈远",
&"id": "1",
&"next_id": "2",
&"static_id": "",
&"text": "怎么……破败成这样了。",
&"type": "dialogue"
},
"10": {
&"id": "10",
&"is_snippet": false,
&"next_id": "end",
&"next_id_after": "",
&"type": "goto"
},
"11": {
&"id": "11",
&"next_id": "12",
&"type": ""
},
"12": {
&"id": "12",
&"is_snippet": false,
&"next_id": "end",
&"next_id_after": "",
&"type": "goto"
},
"2": {
&"character": "陈伯",
&"id": "2",
&"next_id": "3",
&"static_id": "",
&"text": "哟，是远儿吧？都长这么高了！",
&"type": "dialogue"
},
"3": {
&"character": "陈远",
&"id": "3",
&"next_id": "4",
&"static_id": "",
&"text": "您是……？",
&"type": "dialogue"
},
"4": {
&"character": "陈伯",
&"id": "4",
&"next_id": "5",
&"static_id": "",
&"text": "我是你守田伯，还记得不？你小时候骑在我脖子上够过槐花。",
&"type": "dialogue"
},
"5": {
&"character": "陈伯",
&"id": "5",
&"next_id": "6",
&"static_id": "",
&"text": "来，先把这院子拾掇拾掇。草都长到膝盖了。",
&"type": "dialogue"
},
"6": {
&"character": "陈伯",
&"id": "6",
&"next_id": "7",
&"static_id": "",
&"text": "记住喽——收拾房子先收拾院子，这是规矩。",
&"type": "dialogue"
},
"7": {
&"character": "陈伯",
&"id": "7",
&"next_id": "8",
&"static_id": "",
&"text": "咱们这四合院，讲究个方正。院子是宅子的\"气口\"，院子堵了，整座宅子的气就散了。",
&"type": "dialogue"
},
"8": {
&"character": "陈伯",
&"id": "8",
&"next_id": "9",
&"static_id": "",
&"text": "你爷爷当年跟我说过，四合院这东西，从元大都那会儿就有了。正房坐北朝南，这叫\"坎宅巽门\"——大门开在东南角，取个紫气东来的意思。",
&"type": "dialogue"
},
"9": {
&"character": "陈伯",
&"id": "9",
&"next_id": "10",
&"static_id": "",
&"text": "靠近杂草按交互键就能清理，去吧！",
&"type": "dialogue"
}
}
metadata/dialogue_manager_version = "3.10.1"
