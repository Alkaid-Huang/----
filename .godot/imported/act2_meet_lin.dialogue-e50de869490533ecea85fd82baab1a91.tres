"1": {
&"character": "林师傅",
&"id": "1",
&"next_id": "2",
&"static_id": "",
&"text": "你就是陈怀瑾的孙子？",
&"type": "dialogue"
},
"2": {
&"character": "陈远",
&"id": "2",
&"next_id": "3",
&"static_id": "",
&"text": "是的，您认识我爷爷？",
&"type": "dialogue"
},
"3": {
&"character": "林师傅",
&"id": "3",
&"next_id": "4",
&"static_id": "",
&"text": "你爷爷是我的启蒙师傅。二十年前我跟着他修过关帝庙。",
&"type": "dialogue"
},
"4": {
&"character": "林师傅",
&"id": "4",
&"next_id": "5",
&"static_id": "",
&"text": "上梁是大事，日子我看好了——就今天辰时。",
&"type": "dialogue"
},
"5": {
&"character": "林师傅",
&"id": "5",
&"next_id": "6",
&"static_id": "",
&"text": "去选一根好木料吧，靠近木料按交互键选取。",
&"type": "dialogue"
},
"6": {
&"id": "6",
&"is_snippet": false,
&"next_id": "end",
&"next_id_after": "",
&"type": "goto"
},
