"1": {
&"character": "陈伯",
&"id": "1",
&"next_id": "2",
&"static_id": "",
&"text": "嗯，这才像话。院子一干净，整个宅子都精神了。",
&"type": "dialogue"
},
"2": {
&"character": "陈伯",
&"id": "2",
&"next_id": "3",
&"static_id": "",
&"text": "来，喝口茉莉花茶。你爷爷以前最爱喝的。",
&"type": "dialogue"
},
"3": {
&"character": "陈远",
&"id": "3",
&"next_id": "4",
&"static_id": "",
&"text": "守田伯……我想把老宅修好。",
&"type": "dialogue"
},
"4": {
&"character": "陈伯",
&"id": "4",
&"next_id": "5",
&"static_id": "",
&"text": "好！就等你这句话！",
&"type": "dialogue"
},
"5": {
&"character": "陈伯",
&"id": "5",
&"next_id": "6",
&"static_id": "",
&"text": "你爷爷的作坊里还留着老图纸，你先去看看。",
&"type": "dialogue"
},
